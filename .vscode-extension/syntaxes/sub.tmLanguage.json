{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SUB",
  "scopeName": "source.sub",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#embedded-code"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.sub",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.sub",
          "match": "\\b(if|elif|else|for|while|do|end|break|continue|return|try|catch|finally|throw)\\b"
        },
        {
          "name": "keyword.declaration.sub",
          "match": "\\b(var|const|let|function|fn|def|class|extends|implements|import)\\b"
        },
        {
          "name": "keyword.other.sub",
          "match": "\\b(print|show|input|embed|endembed|new|this|super|static|private|public|protected|async|await|yield|in|range)\\b"
        },
        {
          "name": "constant.language.sub",
          "match": "\\b(true|false|null)\\b"
        },
        {
          "name": "support.type.sub",
          "match": "\\b(int|float|string|bool|auto|void|list|dict|array)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sub",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sub",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.sub",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.sub",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.sub",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.hex.sub",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.sub",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.octal.sub",
          "match": "\\b0[oO][0-7]+\\b"
        },
        {
          "name": "constant.numeric.integer.sub",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.sub",
          "match": "(?<=\\b(function|fn|def)\\s)\\w+"
        },
        {
          "name": "entity.name.function.call.sub",
          "match": "\\b\\w+(?=\\()"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.declaration.sub",
          "match": "(?<=\\b(var|const|let)\\s)\\w+"
        },
        {
          "name": "variable.other.sub",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.sub",
          "match": "\\+|\\-|\\*|\\/|%|\\*\\*"
        },
        {
          "name": "keyword.operator.comparison.sub",
          "match": "==|!=|<|>|<=|>="
        },
        {
          "name": "keyword.operator.logical.sub",
          "match": "\\band\\b|\\bor\\b|\\bnot\\b|&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.sub",
          "match": "=|\\+=|-=|\\*=|\\/="
        }
      ]
    },
    "embedded-code": {
      "patterns": [
        {
          "name": "meta.embedded.block.python",
          "begin": "\\bembed\\s+python\\b",
          "end": "\\bendembed\\b",
          "patterns": [
            {
              "include": "source.python"
            }
          ]
        },
        {
          "name": "meta.embedded.block.javascript",
          "begin": "\\bembed\\s+javascript\\b",
          "end": "\\bendembed\\b",
          "patterns": [
            {
              "include": "source.js"
            }
          ]
        },
        {
          "name": "meta.embedded.block.c",
          "begin": "\\bembed\\s+c\\b",
          "end": "\\bendembed\\b",
          "patterns": [
            {
              "include": "source.c"
            }
          ]
        },
        {
          "name": "meta.embedded.block.cpp",
          "begin": "\\bembed\\s+cpp\\b",
          "end": "\\bendembed\\b",
          "patterns": [
            {
              "include": "source.cpp"
            }
          ]
        },
        {
          "name": "meta.embedded.block.rust",
          "begin": "\\bembed\\s+rust\\b",
          "end": "\\bendembed\\b",
          "patterns": [
            {
              "include": "source.rust"
            }
          ]
        },
        {
          "name": "meta.embedded.block.generic",
          "begin": "\\bembed\\s+\\w+\\b",
          "end": "\\bendembed\\b",
          "contentName": "meta.embedded.content.sub"
        }
      ]
    }
  }
}
